{
  "include": ["src"],
  "exclude": ["node_modules", "dts"],  // Fixed the exclude pattern
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "target": "esnext",
    "module": "esnext",
    "jsx": "react-jsx",
    "jsxImportSource": "@emotion/react",
  
    "outDir": "dts",

    "paths": {
      "@/*": [
        "./src/@/*"
      ]
    }
  }
}